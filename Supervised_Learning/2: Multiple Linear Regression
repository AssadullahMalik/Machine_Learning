import pandas as pd
from sklearn.linear_model import LinearRegression

df = pd.DataFrame({
    "Area": [1000, 1500, 2000, 2500],
    "Bedrooms": [2, 3, 3, 4],
    "Price": [200000, 300000, 400000, 500000]
})

X = df[["Area", "Bedrooms"]]
y = df["Price"]

model = LinearRegression()
model.fit(X, y)

print(model.predict([[1800, 3]]))
